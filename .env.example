# LocalSky environment configuration template.
#
# For new deployments: copy to .env and fill in your values.
# For existing deployments: this file documents every supported env var; the
# canonical config lives in /data/localsky.toml from v0.2 onward. Env vars
# remain supported as overrides and as a back-compat path for v0.1 deployments.
#
# Anything in this file is safe to commit. Real secrets belong in your own .env
# (not tracked) or in your reverse-proxy / secrets-manager.

# ----- Runtime -----
TZ=America/New_York
PUID=1000
PGID=1000

# Bind port. The container listens on 8090 by default; the external port can
# be remapped at the docker run / compose layer.
LOCALSKY_PORT_1_EXT=8090
LOCALSKY_PORT_1_INT=8090

# ----- Location -----
# Required when no /data/localsky.toml exists yet. Used by the Open-Meteo
# adapter, the radar tile center, and the sunset compute. The first-run
# wizard will write these into the TOML and then env-var values are ignored.
WEATHER_APP_LAT=0.0
WEATHER_APP_LON=0.0
WEATHER_APP_ZOOM=10

# ----- Home Assistant (optional from v0.2) -----
# v0.1: required if you want any irrigation control or skip-check verdict.
# v0.2+: optional. When set, LocalSky synthesizes an `ha_service_call`
# controller and an `ha_passthrough` source for back-compat. Leave blank to
# run without HA; configure local controllers + sources in the wizard.
HA_URL=
HA_LONG_LIVED_TOKEN=

# ----- LLM advisor (optional) -----
# Set provider to "auto" to probe Ollama (localhost:11434), llama.cpp
# (localhost:8080), and LM Studio (localhost:1234) in order. Or point at any
# OpenAI-compatible endpoint via LLM_BASE_URL.
LLM_PROVIDER=auto
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_S=20
LLM_ADVISOR_DISABLED=0

# Legacy alias for LLM_MODEL; read only when LLM_MODEL is unset.
LLM_ADVISOR_MODEL=

# ----- Web Push (optional) -----
# Generate a VAPID keypair with:
#   openssl ecparam -name prime256v1 -genkey -noout -out vapid-private.pem
#   openssl ec -in vapid-private.pem -pubout -outform DER 2>/dev/null \
#     | tail -c 65 | base64 -w0 | tr '+/' '-_' | tr -d '='
# Public key is base64url-encoded raw P-256 (87 chars). Private key is
# PEM-encoded EC P-256 (SEC1 format). Leave VAPID_PUBLIC_KEY empty to
# disable push entirely; the API endpoints stay mounted but
# /api/push/vapid-key returns 503.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_PATH=/keys/vapid-private.pem
VAPID_SUBJECT=mailto:you@example.com

# ----- MQTT (optional, for HA discovery publish) -----
# When set, LocalSky publishes its zone/verdict/ET sensors to HA via MQTT
# discovery so HA users get sensor.localsky_* entities automatically.
MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_DISCOVERY_PREFIX=homeassistant

# ----- Demo mode -----
# Set to 1 to boot with simulated data and a DryRun controller. Used for
# screenshots, public demos, and offline UI development.
LOCALSKY_DEMO=0

# ----- Persistence -----
# SQLite database path inside the container. Mount /data as a volume.
HISTORY_DB_PATH=/data/irrigation.db
CONFIG_PATH=/data/localsky.toml
